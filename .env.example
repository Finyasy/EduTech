# Leave empty to use mock data (no DB). For a real DB, set:
# - DATABASE_URL: pooled/runtime URL
# - DIRECT_URL: direct DB URL for migrate/seed (recommended for Neon)
# - MIGRATE_DATABASE_URL: optional override used only for migrate/seed
DATABASE_URL=""
DIRECT_URL=""
MIGRATE_DATABASE_URL=""
# Optional when deploying on Vercel if VERCEL_PROJECT_PRODUCTION_URL is available.
NEXT_PUBLIC_APP_URL="https://your-production-domain.vercel.app"
# Get real values at https://dashboard.clerk.com → API Keys (replace placeholders)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="<your-clerk-publishable-key>"
CLERK_SECRET_KEY="<your-clerk-secret-key>"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
# Optional: set to 1 only when intentionally disabling social login.
NEXT_PUBLIC_CLERK_DISABLE_SOCIAL="0"
# Comma-separated list of admin and teacher emails used for role mapping
ADMIN_EMAILS="admin@example.com"
TEACHER_EMAILS="teacher@example.com"
