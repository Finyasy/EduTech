generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum QuestionType {
  MULTIPLE_CHOICE
  SHORT_ANSWER
}

enum TeacherSessionLearnerStatus {
  PRACTICED_ENOUGH
  KEEP_GOING
  NEED_MORE_PRACTICE
}

model User {
  id           String          @id
  email        String          @unique
  name         String?
  role         UserRole        @default(STUDENT)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  progress     LessonProgress[]
  quizAttempts QuizAttempt[]
  gameAttempts GameAttempt[]
  gameBests    GameBest[]
}

model Course {
  id               String   @id @default(cuid())
  title            String
  description      String
  gradeLevel       String
  ageBand          String?
  pathwayStage     String?
  aiFocus          String?
  codingFocus      String?
  mathFocus        String?
  missionOutcome   String?
  sessionBlueprint String?
  isPublished      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lessons          Lesson[]
}

model Lesson {
  id          String          @id @default(cuid())
  courseId    String
  title       String
  videoId     String
  order       Int
  notes       String
  isPublished Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  course      Course          @relation(fields: [courseId], references: [id])
  questions   QuizQuestion[]
  progress    LessonProgress[]
  attempts    QuizAttempt[]

  @@unique([courseId, order])
}

model QuizQuestion {
  id          String       @id @default(cuid())
  lessonId    String
  type        QuestionType
  question    String
  options     Json?
  answer      String
  explanation String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  lesson      Lesson       @relation(fields: [lessonId], references: [id])
}

model Game {
  id          String      @id @default(cuid())
  title       String
  description String
  isPublished Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  levels      GameLevel[]
  bests       GameBest[]
}

model GameLevel {
  id          String        @id @default(cuid())
  gameId      String
  levelNumber Int
  configJson  Json
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  game        Game          @relation(fields: [gameId], references: [id])
  attempts    GameAttempt[]

  @@unique([gameId, levelNumber])
}

model LessonProgress {
  id           String   @id @default(cuid())
  userId       String
  lessonId     String
  completedAt  DateTime?
  watchPercent Int
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
  lesson       Lesson   @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  score       Int
  submittedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  lesson      Lesson   @relation(fields: [lessonId], references: [id])
}

model GameAttempt {
  id          String   @id @default(cuid())
  userId      String
  gameLevelId String
  score       Int
  timeMs      Int
  submittedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  level       GameLevel @relation(fields: [gameLevelId], references: [id])
}

model GameBest {
  id         String   @id @default(cuid())
  userId     String
  gameId     String
  bestScore  Int
  bestTimeMs Int
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
  game       Game     @relation(fields: [gameId], references: [id])

  @@unique([userId, gameId])
}

model TeacherSchoolProfile {
  id                 String   @id @default(cuid())
  ownerKey           String   @unique
  schoolName         String
  country            String
  appVersion         String
  deviceId           String
  connectivityStatus String
  contentStatus      String
  supportEmail       String
  schoolQrCode       String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model TeacherClassroom {
  id            String               @id @default(cuid())
  ownerKey      String
  name          String
  grade         String
  teacherName   String
  teacherPhone  String
  cardColor     String
  isArchived    Boolean              @default(false)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  learners      TeacherLearner[]
  sessionStatus TeacherSessionStatus[]
  assignments   TeacherMissionAssignment[]

  @@index([ownerKey, isArchived])
}

model TeacherLearner {
  id            String               @id @default(cuid())
  classId       String
  name          String
  avatarHue     Int
  weeklyMinutes Int                  @default(0)
  lastWeekMinutes Int                @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  classroom     TeacherClassroom     @relation(fields: [classId], references: [id], onDelete: Cascade)
  sessionStatus TeacherSessionStatus[]

  @@index([classId])
}

model TeacherSessionStatus {
  id         String                       @id @default(cuid())
  classId    String
  learnerId  String
  activityId String
  status     TeacherSessionLearnerStatus @default(KEEP_GOING)
  updatedAt  DateTime                     @updatedAt
  classroom  TeacherClassroom             @relation(fields: [classId], references: [id], onDelete: Cascade)
  learner    TeacherLearner               @relation(fields: [learnerId], references: [id], onDelete: Cascade)

  @@unique([classId, learnerId, activityId])
  @@index([classId, activityId])
}

model TeacherMissionAssignment {
  id         String          @id @default(cuid())
  ownerKey   String
  classId    String
  dedupeKey  String          @unique
  courseId   String
  courseTitle String
  target     String
  subjectId  String?
  strandId   String?
  activityId String?
  learnerIds Json?
  note       String?
  status     String          @default("ASSIGNED")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  classroom  TeacherClassroom @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([ownerKey, classId, updatedAt])
  @@index([ownerKey, status])
  @@index([classId, target])
}
